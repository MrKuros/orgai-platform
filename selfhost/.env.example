# Copy to .env and fill in before `docker compose up -d`.

# Any long random string. Generate one with:  openssl rand -hex 32
JWT_SECRET=

# Password for the bundled Postgres (stays inside Docker, pick anything strong)
POSTGRES_PASSWORD=

# Ports on this machine (change if taken)
DASHBOARD_PORT=3000
API_PORT=8080

# After first login: create an API key in the dashboard (Settings -> API Keys),
# paste it here, then run `docker compose up -d` again. This turns on the
# built-in MCP server your AI agents connect to.
COMPLY_API_KEY=

# Only needed if people access the dashboard from other machines on your network:
# set these to this machine's hostname/IP, e.g. http://orgai.internal:3000
#CORS_ORIGIN=http://localhost:3000
#DASHBOARD_URL=http://localhost:3000
