# Database (used by Docker Compose local postgres)
DATABASE_URL=postgresql://orgai:orgai@localhost:5432/orgai
# Direct (non-pooler) connection — required for Prisma migrations on Neon
DIRECT_DATABASE_URL=postgresql://orgai:orgai@localhost:5432/orgai

# API
JWT_SECRET=change-this-to-a-random-32-char-string
WORKOS_API_KEY=sk_test_placeholder
WORKOS_CLIENT_ID=client_placeholder
WORKOS_REDIRECT_URI=http://localhost:8080/v1/auth/sso/callback

# MCP
COMPLY_API_KEY=oai_your_key_here
COMPLY_USER_ROLE=junior
