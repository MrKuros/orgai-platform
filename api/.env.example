# --- Required ---
DATABASE_URL=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/neondb?sslmode=require
JWT_SECRET=your-random-32-char-string-here-change-this
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Optional: direct (non-pooled) connection for Prisma migrations on Neon ---
# DIRECT_DATABASE_URL=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/neondb?sslmode=require

# --- Optional: transactional email (Resend). If unset, emails are logged, not sent ---
# RESEND_API_KEY=re_placeholder
# EMAIL_FROM=OrgAI <noreply@orgai.dev>
# DASHBOARD_URL=https://app.orgai.dev

# --- Optional: WorkOS SSO. If unset, SSO endpoints return 501 and password auth still works ---
# WORKOS_API_KEY=sk_test_placeholder
# WORKOS_CLIENT_ID=client_placeholder
# WORKOS_REDIRECT_URI=http://localhost:8080/v1/auth/sso/callback

# --- Optional: public URL of this API (used by merged-mode MCP self-calls) ---
# ORGAI_API_URL=https://api.orgai.dev

# --- Tests ---
DATABASE_URL_TEST=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/orgai-test?sslmode=require
